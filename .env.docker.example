# Copy to .env in the repo root before running `docker compose up`.
#
#   cp .env.docker.example .env
#
# Generate a fresh APP_KEY with: docker compose run --rm backend php artisan key:generate --show

APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8000
LOG_LEVEL=debug

# MySQL (inside the network the host is `mysql`; outside use 127.0.0.1:${DB_PORT_HOST})
DB_DATABASE=pms
DB_USERNAME=pms
DB_PASSWORD=pms
DB_ROOT_PASSWORD=rootpms
DB_PORT_HOST=3307

# Sanctum / sessions
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# Ports exposed on the host
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Frontend build args (baked into the JS bundle at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME=PMS
NEXT_PUBLIC_FCM_VAPID_KEY=

# SMS gateway — leave provider=log for local testing
SMS_PROVIDER=log
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=PMS
