APP_NAME="PMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Dhaka
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pms
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=30

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# Mail (use log driver in dev, switch to SMTP for production)
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@pms.test"
MAIL_FROM_NAME="${APP_NAME}"

# SMS gateway (Bangladesh) — placeholder, plug your provider
SMS_PROVIDER=log
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=PMS

# FCM
FCM_SERVER_KEY=
FCM_SENDER_ID=

# OTP
OTP_LENGTH=6
OTP_TTL_MINUTES=5

# Audit retention
AUDIT_RETENTION_YEARS=5

# Currency
CURRENCY=BDT
LOCALE_BENGALI_ENABLED=true
